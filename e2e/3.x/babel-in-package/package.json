{
  "name": "vue3-babel-in-package",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "test": "jest --no-cache test.js"
  },
  "dependencies": {
    "vue": "^3.2.22"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.4",
    "@vue/babel-plugin-jsx": "^1.1.5",
    "@vue/vue3-jest": "^30.0.0",
    "coffeescript": "^2.3.2",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "ts-jest": "^29.4.0",
    "typescript": ">=5.4.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleFileExtensions": [
      "js",
      "json",
      "vue",
      "mts",
      "cts"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest",
      "^.+\\.vue$": "@vue/vue3-jest"
    }
  },
  "babel": {
    "presets": [
      "@babel/env"
    ],
    "plugins": [
      "@vue/babel-plugin-jsx"
    ]
  }
}
